    <%- include('../includes/header.ejs') %>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>

    <div class="profile-page">
    <div class="container py-4">
        
        <!-- Page Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex align-items-center gap-3">
                    <a href="/dashboard" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-arrow-left me-2"></i>
                        <span class="d-none d-md-inline">Torna alla Dashboard</span>
                        <span class="d-md-none">Indietro</span>
                    </a>
                    <div>
                        <h2 class="mb-0 fw-bold">Il Mio Profilo</h2>
                        <p class="text-muted mb-0 small">Gestisci le tue informazioni personali</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            
            <!-- Left Column: Profile Info & Stats -->
            <div class="col-lg-4">
                
                <!-- Profile Card -->
                <div class="card border-0 shadow-sm rounded-3 profile-card mb-4">
                    <div class="card-body p-4 text-center">
                        
                        <!-- Avatar -->
                        <div class="avatar-wrapper mb-3">
                            <img src="<%= user.avatarUrl || 'https://ui-avatars.com/api/?name=' + (user.name || user.username) + '&size=150&background=0d6efd&color=fff' %>" 
                                alt="Avatar" class="avatar-img" id="avatarImg">
                            <button class="avatar-edit-btn" onclick="document.getElementById('avatarUpload').click()">
                                <i class="fa-solid fa-camera"></i>
                            </button>
                            <input type="file" id="avatarUpload" accept="image/*" style="display: none;" onchange="handleAvatarUpload(this)">
                        </div>

                        <!-- User Info -->
                        <h4 class="mb-1 fw-bold">
                            <%= user.name && user.lastName ? user.name + ' ' + user.lastName : user.username %>
                            <% if (user.isVerified) { %>
                                <i class="fa-solid fa-circle-check text-primary ms-1" data-bs-toggle="tooltip" title="Account Verificato"></i>
                            <% } %>
                        </h4>
                        <p class="text-muted mb-2">@<%= user.username %></p>
                        
                        <!-- Bio -->
                        <% if (user.userBio) { %>
                        <p class="user-bio text-muted small mb-3">
                            <%= user.userBio %>
                        </p>
                        <% } %>

                        <!-- Member Since -->
                        <div class="member-since mb-3">
                            <small class="text-muted">
                                <i class="fa-solid fa-calendar-days me-1"></i>
                                Membro dal <%= new Date(user.createdAt).toLocaleDateString('it-IT', { month: 'long', year: 'numeric' }) %>
                            </small>
                        </div>

                        <!-- Quick Actions -->
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                                <i class="fa-solid fa-key me-2"></i>
                                Cambia Password
                            </button>
                        </div>

                    </div>
                </div>

                <!-- Stats Card -->
                <div class="card border-0 shadow-sm rounded-3 stats-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fa-solid fa-chart-simple text-primary me-2"></i>
                            Le Tue Statistiche
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="stat-item">
                            <div class="stat-icon stat-icon-inventory">
                                <i class="fa-solid fa-box"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value"><%= stats.itemAmount || 0 %></div>
                                <div class="stat-label">Articoli in Dispensa</div>
                            </div>
                        </div>

                        <div class="stat-item">
                            <div class="stat-icon stat-icon-todos">
                                <i class="fa-solid fa-list-check"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value"><%= stats.todoAmount || 0 %></div>
                                <div class="stat-label">Attività da Fare</div>
                            </div>
                        </div>

                        <div class="stat-item">
                            <div class="stat-icon stat-icon-shopping">
                                <i class="fa-solid fa-cart-shopping"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-value"><%= stats.shoppingListAmount || 0 %></div>
                                <div class="stat-label">Lista della Spesa</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Right Column: Details & Preferences -->
            <div class="col-lg-8">
                
                <!-- Contact Information Card WITH INLINE EDITING -->
                <div class="card border-0 shadow-sm rounded-3 mb-4 info-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0 fw-semibold">
                                <i class="fa-solid fa-address-card text-primary me-2"></i>
                                Informazioni di Contatto
                            </h6>
                            <button class="btn btn-sm btn-outline-primary" id="toggleEditBtn" onclick="toggleEditMode()">
                                <i class="fa-solid fa-pen-to-square me-1"></i>
                                <span id="editBtnText">Modifica</span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <form method="POST" id="profileForm" action="/profile/edit-profile">
                            <div class="row g-3">
                                
                                <!-- Nome -->
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <div class="info-icon">
                                            <i class="fa-solid fa-user"></i>
                                        </div>
                                        <div class="info-content">
                                            <div class="info-label">Nome</div>
                                            <div class="info-value" id="nameDisplay"><%= user.name || 'Non fornito' %></div>
                                            <input type="text" class="form-control d-none edit-input" id="nameInput" name="name" value="<%= user.name || '' %>" placeholder="Inserisci nome">
                                        </div>
                                    </div>
                                </div>

                                <!-- Cognome -->
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <div class="info-icon">
                                            <i class="fa-solid fa-user"></i>
                                        </div>
                                        <div class="info-content">
                                            <div class="info-label">Cognome</div>
                                            <div class="info-value" id="lastNameDisplay"><%= user.lastName || 'Non fornito' %></div>
                                            <input type="text" class="form-control d-none edit-input" id="lastNameInput" name="lastName" value="<%= user.lastName || '' %>"placeholder="Inserisci cognome">
                                        </div>
                                    </div>
                                </div>

                                <!-- Email -->
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <div class="info-icon">
                                            <i class="fa-solid fa-envelope"></i>
                                        </div>
                                        <div class="info-content">
                                            <div class="info-label">Email</div>
                                            <div class="info-value" id="emailDisplay"><%= user.email %></div>
                                            <input type="email" class="form-control d-none edit-input" id="emailInput" name="email" value="<%= user.email %>" placeholder="Inserisci email" required>
                                        </div>
                                    </div>
                                </div>

                                <!-- Telefono -->
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <div class="info-icon">
                                            <i class="fa-solid fa-phone"></i>
                                        </div>
                                        <div class="info-content">
                                            <div class="info-label">Telefono</div>
                                            <div class="info-value" id="phoneDisplay"><%= user.phoneNumber || 'Non fornito' %></div>
                                            <input type="tel" class="form-control d-none edit-input" id="phoneInput" name="phoneNumber" value="<%= user.phoneNumber || '' %>" placeholder="Inserisci telefono">
                                        </div>
                                    </div>
                                </div>

                                <!-- Telegram -->
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <div class="info-icon">
                                            <i class="fa-brands fa-telegram"></i>
                                        </div>
                                        <div class="info-content">
                                            <div class="info-label">Telegram</div>
                                            <div class="info-value" id="telegramDisplay">
                                                <% if (user.telegramId) { %>
                                                    @<%= user.telegramId.username %>
                                                <% } else { %>
                                                    Non collegato
                                                <% } %>
                                            </div>
                                            <div class="input-group d-none edit-input" id="telegramInputGroup">
                                                <span class="input-group-text">@</span>
                                                <input type="text" class="form-control" id="telegramInput" name="telegramUsername" value="<%= user.telegramId.username || '' %>" placeholder="username">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Bio -->
                                <div class="col-md-6">
                                    <div class="info-item">
                                        <div class="info-icon">
                                            <i class="fa-solid fa-comment"></i>
                                        </div>
                                        <div class="info-content">
                                            <div class="info-label">Bio</div>
                                            <div class="info-value" id="bioDisplay"><%= user.userBio || 'Non fornita' %></div>
                                            <textarea class="form-control d-none edit-input" id="bioInput" name="userBio" rows="3" maxlength="200" placeholder="Racconta qualcosa di te..."><%= user.userBio || '' %></textarea>
                                            <small class="text-muted d-none edit-input">Max 200 caratteri</small>
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <!-- Action Buttons (shown only in edit mode) -->
                            <div class="d-none mt-4 pt-3 border-top" id="editActions">
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa-solid fa-floppy-disk me-2"></i>
                                        Salva Modifiche
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="cancelEdit()">
                                        <i class="fa-solid fa-xmark me-2"></i>
                                        Annulla
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Preferences Card -->
                <div class="card border-0 shadow-sm rounded-3 mb-4 preferences-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-3">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fa-solid fa-sliders text-primary me-2"></i>
                            Preferenze
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        <form id="preferencesForm">
                            
                            <!-- Language Selection -->
                            <div class="preference-item mb-4">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <label class="form-label fw-semibold mb-1">
                                            <i class="fa-solid fa-language text-primary me-2"></i>
                                            Lingua
                                        </label>
                                        <p class="text-muted small mb-0">Seleziona la lingua dell'interfaccia</p>
                                    </div>
                                </div>
                                <select class="form-select form-select-lg" id="language" name="language">
                                    <option value="it" selected>🇮🇹 Italiano</option>
                                    <option value="en">🇬🇧 English</option>
                                    <option value="es">🇪🇸 Español</option>
                                    <option value="fr">🇫🇷 Français</option>
                                    <option value="de">🇩🇪 Deutsch</option>
                                </select>
                            </div>

                            <!-- Email Notifications -->
                            <div class="preference-item mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <label class="form-label fw-semibold mb-1">
                                            <i class="fa-solid fa-envelope text-primary me-2"></i>
                                            Notifiche Email
                                        </label>
                                        <p class="text-muted small mb-0">Ricevi aggiornamenti via email</p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="emailNotifications" name="emailNotifications" checkedstyle="width: 3rem; height: 1.5rem; cursor: pointer;">
                                    </div>
                                </div>
                            </div>

                            <!-- Todo Reminders -->
                            <div class="preference-item mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <label class="form-label fw-semibold mb-1">
                                            <i class="fa-solid fa-bell text-primary me-2"></i>
                                            Promemoria Attività
                                        </label>
                                        <p class="text-muted small mb-0">Ricevi promemoria per le tue attività</p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="todoReminders" name="todoReminders" checked style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                    </div>
                                </div>
                            </div>

                            <!-- Shopping List Notifications -->
                            <div class="preference-item mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <label class="form-label fw-semibold mb-1">
                                            <i class="fa-solid fa-cart-shopping text-primary me-2"></i>
                                            Notifiche Lista Spesa
                                        </label>
                                        <p class="text-muted small mb-0">Avvisi per articoli in scadenza</p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="shoppingNotifications" name="shoppingNotifications" checked style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                    </div>
                                </div>
                            </div>

                            <!-- Low Stock Alerts -->
                            <div class="preference-item mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <label class="form-label fw-semibold mb-1">
                                            <i class="fa-solid fa-triangle-exclamation text-primary me-2"></i>
                                            Avvisi Scorte Basse
                                        </label>
                                        <p class="text-muted small mb-0">Notifiche quando gli articoli stanno per finire</p>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="lowStockAlerts" name="lowStockAlerts" checked style="width: 3rem; height: 1.5rem; cursor: pointer;">
                                    </div>
                                </div>
                            </div>

                            <!-- Save Preferences Button -->
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fa-solid fa-floppy-disk me-2"></i>
                                    Salva Preferenze
                                </button>
                            </div>

                        </form>
                    </div>
                </div>

                <!-- Danger Zone Card -->
                <div class="card border-0 shadow-sm rounded-3 danger-card">
                    <div class="card-header bg-white border-0 pt-4 px-4 pb-3">
                        <h6 class="mb-0 fw-semibold text-danger">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i>
                            Zona Pericolosa
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="alert alert-danger mb-3" role="alert">
                            <i class="fa-solid fa-circle-exclamation me-2"></i>
                            <strong>Attenzione:</strong> Queste azioni sono irreversibili
                        </div>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-danger" onclick="confirmAccountDeletion()">
                                <i class="fa-solid fa-trash-can me-2"></i>
                                Elimina Account
                            </button>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- Change Password Modal -->
<div class="modal fade" id="changePasswordModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">
                    <i class="fa-solid fa-key text-danger me-2"></i>
                    Cambia Password
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="changePasswordForm">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label fw-semibold">
                            Password Attuale <span class="text-danger">*</span>
                        </label>
                        <div class="position-relative">
                            <input type="password" class="form-control form-control-lg" id="currentPassword" name="currentPassword" required>
                            <button type="button" class="password-toggle-btn" onclick="togglePasswordField('currentPassword', this)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label fw-semibold">
                            Nuova Password <span class="text-danger">*</span>
                        </label>
                        <div class="position-relative">
                            <input type="password" class="form-control form-control-lg" id="newPassword" name="newPassword" required>
                            <button type="button" class="password-toggle-btn" onclick="togglePasswordField('newPassword', this)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <small class="text-muted">Minimo 8 caratteri</small>
                    </div>
                    <div class="mb-3">
                        <label for="confirmNewPassword" class="form-label fw-semibold">
                            Conferma Nuova Password <span class="text-danger">*</span>
                        </label>
                        <div class="position-relative">
                            <input type="password" class="form-control form-control-lg" id="confirmNewPassword" name="confirmNewPassword" required>
                            <button type="button" class="password-toggle-btn" onclick="togglePasswordField('confirmNewPassword', this)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark me-2"></i>Annulla
                </button>
                <button type="button" class="btn btn-danger" onclick="changePassword()">
                    <i class="fa-solid fa-check me-2"></i>Cambia Password
                </button>
            </div>
        </div>
    </div>
</div>
<script src="/js/profile.js"></script>
<%- include('../includes/footer') %>
