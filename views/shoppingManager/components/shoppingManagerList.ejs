<div class="container shopping-list-container">
    <div class="row">
        <% shoppingList.forEach((item, index) => { %>
            <div class="col-md-6 col-sm-12" id="item_<%= item._id %>">
                <div class="shopping-item card border-0 shadow-sm rounded-3 mb-3" data-item-id="<%= item._id %>">
                    <div class="card-body p-3 p-md-4">
                        <div class="row align-items-center g-3">
                            
                            <!-- Item Name -->
                            <div class="col-md-5 col-lg-6">
                                <div class="d-flex align-items-center">
                                    <div class="item-icon me-3">
                                        <i class="fa-solid fa-basket-shopping text-primary"></i>
                                    </div>
                                    <div>
                                        <input type="text" class="d-none itemNameForm mb-0 fw-semibold text-dark item-name" value="<%= item.itemName %>">
                                        <h5 class="mb-0 fw-semibold text-dark item-name"><%= item.itemName %></h5>
                                        <small class="text-muted">Item #<%= index + 1 %></small>
                                    </div>
                                </div>
                            </div>

                            <!-- Quantity Controls -->
                            <div class="col-md-5 col-lg-4">
                                <div class="quantity-control-wrapper">
                                    <label class="form-label text-muted small mb-2">Quantity</label>
                                    <div class="quantity-control d-flex align-items-center">
                                        <button class="btn btn-outline-secondary btn-qty decrease" type="button" data-item-id="<%= item._id %>" aria-label="Decrease quantity"> 
                                            <i class="fa-solid fa-minus"></i>
                                        </button>
                                        
                                        <input type="number" class="form-control qty-input text-center mx-2" value="<%= item.itemQty %>" min="0" max="999" data-item-id="<%= item._id %>" aria-label="Item quantity">
                                        
                                        <button class="btn btn-outline-secondary btn-qty increase" type="button" data-item-id="<%= item._id %>" aria-label="Increase quantity">
                                            <i class="fa-solid fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="col-md-2 col-lg-2 text-md-end">
                                <button class="btn btn-link text-muted delete-item p-2" data-item-id="<%= item._id %>" data-item-name="<%= item.itemName %>"aria-label="Delete item">
                                    <i class="fa-solid fa-trash-can fs-5"></i>
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
</div>


