<% todos.forEach(todo => { %>
    <article class="todo mt-3" id="todo_<%= todo._id %>">
        <div class="row">
            <div class="col-md-12">
                <div class="card shadow bg-body-tertiary rounded">
                    
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div><%= todo.description %></div>
                        <div><button class="btn deleteTodo" data-todo-desc="<%= todo.description %>" data-todo-id="<%= todo._id %>"><i class="fa-solid fa-xmark"></i></button></div>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title"><%= todo.category %></h5>
                        
                        <div class="row">
                            <div class="col-md-10">
                                <p class="card-text"><%= todo.addDescr %></p>
                                <p class="card-text">Complete by: <%= !_.isNil(todo.completeBy) ? moment(todo.completeBy).format('L') : '-' %></p>
                                <p class="card-text">Completed on: <%= !_.isNil(todo.completedOn) ? moment(todo.completedOn).format('L') : '-' %></p>
                                <!-- <p class="card-text">Aggiunta il: <%= !_.isNil(todo.createdAt) ? moment(todo.createdAt).format('YYYY/MM/DD HH:mm') : '-' %></p> -->
                                <p class="card-text">Aggiunta: <%= handleCreatedAt(todo.createdAt) %></p>
                            </div>
                            
                            <div class="col-md-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" <% if (todo.done) {  %> checked="on" <% } %> id="checkDefault">
                                    <label class="form-check-label" for="checkDefault">
                                        Done
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </article>
<% }); %>


<% 
    function handleCreatedAt(createdAt) {
        let minutes = moment.duration(moment(new Date()).diff(moment(createdAt))).asMinutes().toFixed(0);

        if (minutes < 60) {
            return minutes + ' minuti fa';
        } else if (minutes >= 60 && minutes < 1440) {
            return Math.floor(minutes / 60) + ' ore fa';
        } else if (minutes >= 1440 && minutes < 43200) {
            return Math.floor(minutes / 1440) + ' giorni fa';
        }
    }
%>