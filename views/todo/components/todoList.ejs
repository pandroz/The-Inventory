<% todos.forEach(todo => { %>
<article class="todo mt-3" id="todo_<%= todo._id %>" data-priority="<%= todo.priority ? todo.priority.toLowerCase() : '' %>">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden todo-card priority-<%= todo.priority ? todo.priority.toLowerCase().replace(/\s+/g, '-') : 'none' %>">
                
                <!-- Header with title, priority, and delete button -->
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-start pt-4 px-4 pb-3">
                    <div class="flex-grow-1 pe-3">
                        <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                            <h4 class="mb-0 fw-semibold text-dark LIST_ITEM_TITLE flex-grow-1"><%= todo.description %></h4>
                            <!-- Priority Badge -->
                            <% if (todo.priority) { 
                                const priorityClass = todo.priority.toLowerCase().replace(/\s+/g, '-');
                            %>
                                <span class="badge priority-badge priority-badge-<%= priorityClass %>">
                                    <i class="priority-icon fa-solid fa-circle"></i>
                                    <%= todo.priority %>
                                </span>
                            <% } %>
                        </div>
                        
                        <!-- Badges Row: Category, Recurring, Reminder, Assigned -->
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <!-- Category Badge -->
                            <span class="badge bg-light text-dark border px-3 py-2 fs-6 fw-normal cursor-pointer LIST_ITEM_CATEGORY" data-type="filter" data-todo-category="<%= todo.category %>">
                                <i class="fa-solid fa-tag me-1"></i>
                                <%= todo.category %>
                            </span>
                            
                            <!-- Recurring Badge -->
                            <% if (todo.recurringPattern) { %>
                                <span class="badge badge-recurring" data-bs-toggle="tooltip" data-bs-placement="top" title="Ricorre <%= todo.recurringPattern %>">
                                    <i class="fa-solid fa-rotate me-1"></i>
                                    <%= todo.recurringPattern %>
                                </span>
                            <% } %>
                            
                            <!-- Reminder Badge -->
                            <% if (todo.remindMe && todo.reminderDate) { 
                                const reminderDate = new Date(todo.reminderDate);
                                const now = new Date();
                                const isUpcoming = reminderDate > now;
                            %>
                                <span class="badge badge-reminder <%= isUpcoming ? 'badge-reminder-active' : 'badge-reminder-past' %>" data-bs-toggle="tooltip" data-bs-placement="top" title="Promemoria: <%= moment(todo.reminderDate).fromNow() %>">
                                    <i class="fa-solid fa-bell me-1"></i>
                                    <%= moment(todo.reminderDate).format('YYYY-MM-DD HH:mm') %>
                                </span>
                            <% } %>
                            
                            <!-- Assigned To Badge -->
                            <% if (todo.assignedTo) { %>
                                <span class="badge badge-assigned" data-bs-toggle="tooltip" data-bs-placement="top" title="Assegnato a <%= todo.assignedTo %>">
                                    <i class="fa-solid fa-user me-1"></i>
                                    <%= todo.assignedTo %>
                                </span>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Delete Button -->
                    <button class="btn btn-link text-muted deleteTodo p-0" data-todo-desc="<%= todo.description %>" data-todo-id="<%= todo._id %>" aria-label="Delete todo">
                        <i class="fa-solid fa-xmark fs-4"></i>
                    </button>
                </div>

                <!-- Body with organized information -->
                <div class="card-body px-4 pb-4">
                    
                    <!-- Description -->
                    <% if (todo.addDescr && todo.addDescr.trim()) { %>
                    <div class="mb-3">
                        <p class="text-secondary mb-0 LIST_ITEM_DESC"><%= todo.addDescr %></p>
                    </div>
                    <% } %>

                    <!-- Dates and Status Grid -->
                    <div class="row g-3 align-items-center">
                        
                        <!-- Date Information -->
                        <div class="col-md-9 col-lg-10">
                            <div class="row g-3">
                                
                                <!-- Complete By Date -->
                                <div class="col-sm-6 col-md-4">
                                    <div class="d-flex align-items-start">
                                        <i class="fa-regular fa-calendar text-primary me-2 mt-1"></i>
                                        <div>
                                            <small class="text-muted d-block mb-1">Due Date</small>
                                            <span class="fw-medium text-dark">
                                                <%= !_.isNil(todo.completeBy) ? moment(todo.completeBy).format('L') : 'Not set' %>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Completed On Date -->
                                <div class="col-sm-6 col-md-4">
                                    <div class="d-flex align-items-start">
                                        <i id="todo_<%= todo._id %>_completedIcon" class="fa-regular <%= todo.done ? 'fa-circle-check text-success' : 'fa-circle-xmark text-secondary' %> me-2 mt-1"></i>
                                        <div>
                                            <small class="text-muted d-block mb-1">Completed</small>
                                            <span class="fw-medium text-dark" id="todo_<%= todo._id %>_completedOn">
                                                <%= !_.isNil(todo.completedOn) ? moment(todo.completedOn).format('L') : '-' %>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Created At -->
                                <div class="col-sm-6 col-md-4">
                                    <div class="d-flex align-items-start">
                                        <i class="fa-regular fa-clock text-info me-2 mt-1"></i>
                                        <div>
                                            <small class="text-muted d-block mb-1">Added</small>
                                            <span class="fw-medium text-dark">
                                                <%= handleCreatedAt(todo.createdAt) %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Status Checkbox -->
                        <div class="col-md-3 col-lg-2">
                            <div class="form-check form-switch d-flex align-items-center justify-content-md-end">
                                <input class="form-check-input todoDone me-2 cursor-pointer" data-todo-id="<%= todo._id %>" type="checkbox" role="switch" <% if (todo.done) { %> checked <% } %> id="check_<%= todo._id %>" style="width: 3rem; height: 1.5rem;">
                                <label class="form-check-label fw-medium text-dark cursor-pointer" for="check_<%= todo._id %>">
                                    Done
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <!-- Recurring Task Info (if present) -->
                            <% if (todo.recurringPattern && (todo.recurringStartDate || todo.recurringEndDate)) { %>
                            <div class="recurring-info mt-3">
                                <div class="recurring-info-content">
                                    <i class="fa-solid fa-rotate text-primary me-2"></i>
                                    <span class="small">
                                        <strong>Ricorrenza:</strong>
                                        <% if (todo.recurringStartDate) { %>
                                            Dal <%= moment(todo.recurringStartDate).format('L') %>
                                        <% } %>
                                        <% if (todo.recurringEndDate) { %>
                                            <% if (todo.recurringStartDate) { %> - <% } %>
                                            Fino al <%= moment(todo.recurringEndDate).format('L') %>
                                        <% } %>
                                    </span>
                                </div>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</article>
<% }); %>

<% 
    function handleCreatedAt(createdAt) {
        let minutes = moment.duration(moment(new Date()).diff(moment(createdAt))).asMinutes().toFixed(0);

        if (minutes < 60) {
            return minutes + ' minuti fa';
        } else if (minutes >= 60 && minutes < 1440) {
            return Math.floor(minutes / 60) + ' ore fa';
        } else if (minutes >= 1440 && minutes < 43200) {
            return Math.floor(minutes / 1440) + ' giorni fa';
        }
    }
%>