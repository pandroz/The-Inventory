<%- include('../../includes/header.ejs') %>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/calendar.css" />
</head>

<body>
<div class="container cal-layout">
    <!-- ── Top Bar ── -->
    <header class="cal-topbar">
        <div class="brand">
            <div class="dot"></div>
            Calendar
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="sync-spinner" id="syncSpinner"></div>

            <% if (googleConnected) { %>
                <button class="btn btn-danger" id="btn-google-disconnect">Disconnect</button>
                <span class="sync-badge connected">
                <i class="bi bi-google" style="font-size:10px;"></i>
                Google Synced
                </span>
            <% } else { %>
                <a href="/calendar/google" class="sync-badge disconnected text-decoration-none">
                <i class="bi bi-google" style="font-size:10px;"></i>
                Connect Google
                </a>
            <% } %>
        </div>
    </header>

    <!-- ── Sidebar ── -->
    <aside class="cal-sidebar">

        <!-- Mini Calendar -->
        <div class="mini-calendar">
            <div class="mini-header">
                <button class="mini-nav-btn" id="miniPrev"><i class="bi bi-chevron-left"></i></button>
                <span class="mini-month-label" id="miniMonthLabel"></span>
                <button class="mini-nav-btn" id="miniNext"><i class="bi bi-chevron-right"></i></button>
            </div>
            <div class="mini-grid" id="miniGrid"></div>
        </div>

        <!-- Todays Events -->
        <div>
            <div class="sidebar-section-title">Today</div>
            <div class="upcoming-list" id="upcomingList">
                <%
                    const startOfDay = new Date().setHours(0, 0, 0, 0);
                    const endOfDay = new Date().setHours(23, 59, 59, 999);
                    const todays = _(events)
                        .filter(e => new Date(getEventDate(e)) >= startOfDay && new Date(getEventDate(e)) <= endOfDay && e.status !== 'cancelled')
                        .sortBy(e => new Date(getEventDate(e)))
                        .take(5)
                        .value();
                %>

                <% if (todays.length === 0) { %>
                    <p style="font-size:13px; color:var(--cal-muted);">No events for today.</p>
                <% } %>

                <% todays.forEach(ev => { %>
                    <div class="upcoming-item" onclick="openEventModal('<%= ev.id %>')">
                        <div class="upcoming-dot google"></div>
                        <div>
                        <div class="upcoming-title"><%= ev.summary %></div>
                        <div class="upcoming-time">
                            <%= new Date(getEventDate(ev)).toLocaleDateString('en-GB', { weekday:'short', day:'numeric', month:'short' }) %>
                            <% if (!isEventAllDay(ev)) { %>
                            &nbsp;·&nbsp;
                                <%= new Date(getEventDate(ev)).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
                            <% } %>
                        </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Upcoming Events -->
        <div>
            <div class="sidebar-section-title">Upcoming</div>
            <div class="upcoming-list" id="upcomingList">
                <%
                    const now = new Date();
                    const upcoming = _(events)
                        .filter(e => new Date(getEventDate(e)) >= now && e.status !== 'cancelled')
                        .sortBy(e => new Date(getEventDate(e)))
                        .take(5)
                        .value();
                %>

                <% if (upcoming.length === 0) { %>
                    <p style="font-size:13px; color:var(--cal-muted);">No upcoming events.</p>
                <% } %>

                <% upcoming.forEach(ev => { %>
                    <div class="upcoming-item" onclick="openEventModal('<%= ev.id %>')">
                        <div class="upcoming-dot google"></div>
                        <div>
                        <div class="upcoming-title"><%= ev.summary %></div>
                        <div class="upcoming-time">
                            <%= new Date(getEventDate(ev)).toLocaleDateString('en-GB', { weekday:'short', day:'numeric', month:'short' }) %>
                            <% if (!isEventAllDay(ev)) { %>
                                &nbsp;·&nbsp;
                                <%= new Date(getEventDate(ev)).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
                            <% } %>
                        </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

    </aside>

    <!-- ── Main Calendar ── -->
    <main class="cal-main">

        <!-- Toolbar -->
        <div class="cal-toolbar">
            <div class="d-flex align-items-center gap-2">
                <button class="nav-btn" id="prevMonth"><i class="bi bi-chevron-left"></i></button>
                <button class="nav-btn" id="nextMonth"><i class="bi bi-chevron-right"></i></button>
                <button class="today-btn" id="goToday">Today</button>
                <div>
                    <span class="month-label" id="monthLabel"></span>
                    <span class="year-label" id="yearLabel"></span>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="view-tabs">
                    <button class="view-tab active" data-view="month">Month</button>
                    <button class="view-tab" data-view="week">Week</button>
                    <button class="view-tab" data-view="day">Day</button>
                </div>
                <button class="new-event-btn" data-bs-toggle="modal" data-bs-target="#eventModal" onclick="openNewEventModal()">
                    <i class="bi bi-plus-lg"></i> New event
                </button>
            </div>
        </div>

        <!-- Views — only one is visible at a time (controlled by JS) -->
        <%- include('./components/month-view.ejs') %>
        <%- include('./components/week-view.ejs') %>
        <%- include('./components/day-view.ejs') %>

    </main>
</div>

<!-- ── Event Modal ── -->
<div class="modal fade" id="eventModal" tabindex="-1" aria-labelledby="eventModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="modal-title" id="eventModalLabel">New Event</h5>
                    <span class="event-source-badge app d-none" id="eventSourceBadge">App</span>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
        <div class="modal-body">
            <input type="hidden" id="eventId" />
            <input type="hidden" id="eventGoogleId" />

            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" class="form-control" id="eventTitle" placeholder="Event title" />
            </div>

            <div class="row g-2 mb-3">
                <div class="col">
                    <label class="form-label">Start</label>
                    <input type="datetime-local" class="form-control" id="eventStart" />
                </div>
                <div class="col">
                    <label class="form-label">End</label>
                    <input type="datetime-local" class="form-control" id="eventEnd" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Location</label>
                <input type="text" class="form-control" id="eventLocation" placeholder="Add location (optional)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" id="eventDescription" rows="2" placeholder="Add description (optional)"></textarea>
            </div>

            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="eventAllDay" />
                <label class="form-check-label" style="font-size:13px;" for="eventAllDay">All-day event</label>
            </div>
        </div>

        <div class="modal-footer justify-content-between">
            <button class="btn-delete d-none" id="deleteEventBtn" onclick="deleteEvent()">
            <i class="bi bi-trash3"></i> Delete
            </button>
            <div class="d-flex gap-2 ms-auto">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-save btn btn-sm" onclick="saveEvent()">Save event</button>
            </div>
        </div>

        </div>
    </div>
</div>

<script>
    // ── Inject server-side events into JS ──────────────────────────────────
    // The controller passes `events` as an array of Event documents
    const serverEvents = <%- JSON.stringify(events) %>;

</script>
<script src="js/calendar.js"></script>


<% 
    function getEventDate(ev) {
        return _.get(ev, 'start.dateTime', _.get(ev, 'start.date'));
    }

    function isEventAllDay(ev) {
        return !!ev.start.date && !ev.start.dateTime;
    }
%>

<%- include('../../includes/footer.ejs') %>