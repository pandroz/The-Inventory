<% items.forEach(item => { %>
    <article class="item" id="article_<%= item._id %>">
        <div class="row">
            <h2><%= item.name %></h2>
        </div>
        <div class="row">
            <div class="col-md-2">
                <img src="<%= item.imageUrl || 'https://placehold.co/150?text=No+Image' %>" class="previewImage" alt="<%= item.name %>">
            </div>
            <div class="col-md-5">
                <div class="row">
                    <span><b>Quantità:</b> <%= item.qty %></span>
                </div>
                <div class="row">
                    <span><b>Prezzo:</b> <%= item.price %></span>
                </div>
                
                <div class="row">



                    
                    <div class="btn-toolbar" role="toolbar" aria-label="Toolbar with button groups">
                        <div class="btn-group me-2" role="group" aria-label="First group">
                            
                            <!-- EDIT -->
                            <a href="/inventory/edit-item/<%= item._id %>?edit=true" class="btn btn-primary"><i class="fa-solid fa-pencil"></i></a>
                            
                            <!-- DELETE -->
                            <button data-item-id="<%= item._id %>" data-item-name="<%= item.name %>" class="btn btn-danger deleteItem">
                                <span class="spinner-border spinner-border-sm spinner-delete" role="status" aria-hidden="true" style="display: none;"></span>
                                <i class="fa-solid fa-x icon-delete"></i>
                            </button>
                            
                            <!-- -1 -->
                            <button data-item-id="<%= item._id %>" class="btn btn-warning lessQuantity"><i class="fa-solid fa-minus"></i></button>
                            
                            <!-- +1 -->
                            <button data-item-id="<%= item._id %>" class="btn btn-success moreQuantity"><i class="fa-solid fa-plus"></i></button>
                        </div>
                        
                    </div>
                    
                    <!-- <div class="col-md-1">
                        <a href="/inventory/edit-item/<%= item._id %>?edit=true" class="btn btn-primary"><i class="fa-solid fa-pencil"></i></a>
                    </div> -->

