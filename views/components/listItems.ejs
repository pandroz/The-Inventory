                        <form action="/inventory/deleteItem" method="post">
                            <button class="btn btn-danger"><i class="fa-solid fa-x"></i></button>
                            <input type="hidden" name="itemId" value="<%= item._id %>">
                        </form>
                    </div>

                    <div class="col-md-1">
                        <form action="/inventory/edit-quantity" method="post">
                            <button class="btn btn-warning"><i class="fa-solid fa-minus"></i></button>
                            <input type="hidden" name="itemId" value="<%= item._id %>">
                            <input type="hidden" name="qty" value="<%= item.qty - 1 %>">
                        </form>
                    </div>

                    <div class="col-md-1">
                        <form action="/inventory/edit-quantity" method="post">
                            <button class="btn btn-success"><i class="fa-solid fa-plus"></i></button>
                            <input type="hidden" name="itemId" value="<%= item._id %>">
                            <input type="hidden" name="qty" value="<%= item.qty + 1 %>">
                        </form>
                    </div> -->
                </div>

            </div>
            
            
            
        </div>

        <hr>
    </article>
    

<% }); %>