<div class="d-flex justify-content-center">
    <nav aria-label="Page navigation">
        <ul class="pagination"> 
            <% if(hasPrevPage) { %>
                <li class="page-item">
                    <a class="page-link" href="?page=<%= prevPage %>" aria-label="Previous">Previous</a>
                </li>
            <% } %>

            <% for(let i = 1; i <= lastPage; i++) { %>
                <li class="page-item <% if(i === currentPage) { %> active <% } %>">
                    <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                </li>
            <% } %>

            <% if(hasNextPage) { %>
                <li class="page-item">
                    <a class="page-link" href="?page=<%= nextPage %>" aria-label="Next">Next</a>
                </li>
            <% } %>
        </ul>
    </nav>
</div>