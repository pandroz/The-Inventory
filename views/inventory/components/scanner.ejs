<div class="col-12">
    <label class="form-label fw-semibold">
        <i class="fa-solid fa-barcode text-primary me-1"></i>
        Scansione Barcode
    </label>

    <div class="bc-shell border rounded-3 overflow-hidden" id="bcShell">
        <!-- Controls -->
        <div class="d-flex align-items-center gap-2 p-3 bg-light flex-wrap">
            <select id="bcCameraSelect" class="form-select form-select-sm d-none" style="max-width:200px;">
                <option value="">Camera</option>
            </select>

            <button type="button" class="btn btn-primary" id="bcStartBtn">
                <i class="fa-solid fa-camera"></i> Attiva Scanner
            </button>

            <button
                type="button"
                class="btn btn-outline-secondary btn-sm d-none"
                id="bcFullscreenBtn"
            >
                <i class="fa-solid fa-expand"></i>
            </button>

            <button type="button" class="btn btn-outline-warning btn-sm d-none" id="bcTorchBtn">
                <i class="fa-solid fa-bolt"></i>
            </button>

            <button type="button" class="btn-close d-none" id="bcStopBtn"></button>

            <div class="ms-auto small text-muted">
                <span id="bcStatusText">In attesa…</span>
            </div>
        </div>

        <!-- Scanner -->
        <div id="bcViewport" class="d-none position-relative" style="height: 220px"></div>
        
        <!-- Manual Input -->
        <div id="bcForm" class="border-top p-2">
            <div id="bcInput" class="border-top p-2">
                <label for="bcManualInput" class="form-label fw-semibold">
                    <i class="fa-solid fa-barcode text-primary me-1"></i>
                    Inserisci Barcode
                </label>
                <div class="d-flex align-items-center">
                    <input type="text" name="barcode" class="form-control form-control-sm" id="bcManualInput">
                    <button type="button" class="btn btn-primary btn-sm ms-2" id="bcManualInputSubmit">
                        <i class="fa-solid fa-check"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Result -->
        <div id="bcResult" class="d-none border-top p-2">
            <strong>Scansionato:</strong>
            <code id="bcResultValue"></code>
            <span id="bcResultFormat" class="badge bg-secondary"></span>
        </div>
    </div>
</div>

<!-- Fullscreen -->

<div
    id="bcOverlay"
    style="display: none; position: fixed; inset: 0; background: #000; z-index: 9999"
></div>

<style>
#bcViewport,
#bcOverlay {
    position: relative;
    overflow: hidden;
    background: #000;
}

#bcViewport video,
#bcOverlay video {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
}
</style>

<script src="/js/scanner.js"></script>



