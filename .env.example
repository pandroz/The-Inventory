# ============================================
# Inventario Spesa — Variables d'Ambiente
# Copia questo file in .env e compila i valori
# ============================================

# --- Database ---
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/inventariospesa?retryWrites=true&w=majority

# --- Sessione & CSRF (genera con 'npm run generate-secret') ---
SESSION_SECRET=
CSRF_SECRET=

# --- Telegram Bot (ottieni da @BotFather su Telegram) ---
TELEGRAM_BOT_TOKEN=tuo_bot_token_qui

# --- Google Calendar API (dal Google Cloud Console) ---
GOOGLE_CLIENT_ID=tuo_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tuo_google_client_secret
GOOGLE_REDIRECT_URI=https://localhost:3443/calendar/callback

# --- URL Pubblico (per webhook Google Calendar — usare ngrok in sviluppo) ---
PUBLIC_BASE_URL=https://tua-url-ngrok.ngrok-free.app
WEBHOOK_SECRET=tuo_webhook_secret_casuale

# --- Email SMTP (opzionale, attualmente disabilitato) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_ACTIVATED=false
